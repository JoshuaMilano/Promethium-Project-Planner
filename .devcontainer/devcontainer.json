{
    "name": "Promethium Workspace",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "forwardPorts": [5000],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "tamasfe.even-better-toml"
            ],
            "settings": {
                "files.exclude": {
                    "**/.git": true,
                    "**/.svn": true,
                    "**/.hg": true,
                    "**/.DS_Store": true,
                    "**/Thumbs.db": true,
                    ".env.example": true,
                    "requirements.txt": true
                }
            }
        }
    },
    "postCreateCommand": "sqlite3 promethium.db < schema.sql"
}